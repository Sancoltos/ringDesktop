{
  "name": "ring-desktop",
  "version": "3.0.0",
  "description": "Ring camera viewer with live popup and motion recording",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ring.desktop",
    "productName": "Ring Desktop",
    "asar": true,
    "asarUnpack": [
      "node_modules/@shinyoshiaki/**",
      "node_modules/ring-client-api/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "files": [
      "src/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "ring-client-api": "^14.3.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "patch-package": "^8.0.1"
  }
}
