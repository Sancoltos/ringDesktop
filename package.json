{
  "name": "ring-desktop",
  "version": "3.0.0",
  "description": "Ring camera viewer with live popup and motion recording",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
  "appId": "com.ring.desktop",
  "productName": "Ring Desktop",
  "asar": true,
  "asarUnpack": [
    "node_modules/@shinyoshiaki/**",
    "node_modules/ring-client-api/**"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": "dmg",
    "category": "public.app-category.utilities"
  },
  "files": [
    "src/**/*",
    "package.json"
  ]
}
