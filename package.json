{
  "name": "lazy-ring-doorbell",
  "version": "3.0.0",
  "description": "Ring camera viewer with live popup and motion recording",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ring.desktop",
    "productName": "Lazy Ring Doorbell",
    "icon": "assets/lazyring",
    "asar": true,
    "win": {
      "icon": "assets/lazyring.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/lazyring.icns",
      "category": "public.app-category.utilities"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "ring-client-api": "^14.3.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
  "@shinyoshiaki/binary-data": "npm:@seydx/binary-data@0.6.2"
}
}
